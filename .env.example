# =============================================================================
# Intune Endpoint Tool — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# Azure Entra (MSAL) Authentication — user sign-in to THIS TOOL
# ------------------------------------
# Application (client) ID from your Entra app registration for the tool's own login.
# This can be the same app registration the Jamf tool uses, or a separate one.
AZURE_CLIENT_ID=11111111-2222-3333-4444-555566667777

# Authority URL — use /common for multi-tenant, or replace with your tenant ID
# for single-tenant: https://login.microsoftonline.com/<your-tenant-id>
AZURE_AUTHORITY=https://login.microsoftonline.com/common

# Set to true to bypass Azure auth entirely (local dev/testing only)
SKIP_ENTRA_AUTH=false


# Client (UI) Configuration
# ------------------------------------
CLIENT_HOSTNAME=localhost
CLIENT_PORT=443
THEME=dim

# Optional — only needed behind a reverse proxy (e.g. Caddy). Controls what the
# container actually binds to, decoupled from CLIENT_HOSTNAME/PORT above (which stay
# the public address baked into the browser bundle for MSAL redirect URIs). Falls
# back to CLIENT_HOSTNAME/PORT when unset.
# CLIENT_BIND_HOST=0.0.0.0
# CLIENT_BIND_PORT=3000


# Server (API) Configuration
# ------------------------------------
SERVER_API_HOSTNAME=localhost
SERVER_API_PORT=8443

# Optional — same idea as CLIENT_BIND_HOST/PORT above, for the API container.
# SERVER_BIND_HOST=0.0.0.0
# SERVER_BIND_PORT=3001


# Microsoft Graph / Intune — server-to-Graph client credentials
# ------------------------------------
# This is a SEPARATE Entra app registration from AZURE_CLIENT_ID above: that one signs
# the human in to this tool, this one is what the server uses to call Microsoft Graph
# on the tool's own behalf. Give it admin-consented APPLICATION permissions for:
#   DeviceManagementManagedDevices.ReadWrite.All   (search, wipe, retire)
#   DeviceManagementServiceConfig.ReadWrite.All    (Autopilot deployment profiles, Apple ADE profiles)
#   DeviceManagementConfiguration.Read.All         (device/profile detail reads)
#   Device.ReadWrite.All                           (Entra ID device object cleanup during retire)
# Then create a client secret (or certificate — recommended for production) for it.
GRAPH_TENANT_ID=your-tenant-id
GRAPH_CLIENT_ID=your-graph-app-client-id
GRAPH_CLIENT_SECRET=your-graph-app-client-secret


# GLPI Asset Management (optional)
# ------------------------------------
# GLPI_INSTANCE=https://glpi.yourorg.com/apirest.php
# GLPI_APP_TOKEN=your-glpi-app-token
# GLPI_USER_TOKEN=your-glpi-user-token


# Aruba ClearPass (optional — used during device retire)
# ------------------------------------
# CLEARPASS_INSTANCE=https://clearpass.yourorg.com/api
# CLEARPASS_CLIENT_ID=your-clearpass-client-id
# CLEARPASS_CLIENT_SECRET=your-clearpass-client-secret


# Logging
# ------------------------------------
# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info


# Audit Database (optional)
# ------------------------------------
# Path inside the container where the SQLite audit DB is stored.
# The docker-compose.yml mounts ./audit.db here by default.
# AUDIT_DB_PATH=/app/audit.db
